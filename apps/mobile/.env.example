# Base URL the app uses to reach the ClickRetina API.
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time.
#
# For a physical phone in Expo Go, use your dev machine's LAN IP (same Wi-Fi),
# NOT localhost — the phone can't resolve localhost to your computer.
#   Find it with `ipconfig` (Windows) → IPv4 Address.
#   e.g. EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:54321
EXPO_PUBLIC_API_BASE_URL=http://localhost:54321

# Supabase (auth + user DB). From the dashboard: Settings → API.
# The publishable key (sb_publishable_...) is client-safe; RLS protects your data.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth (Step 6). The WEB client ID from Google Cloud (NOT the Android one).
# The Google button is hidden until this is set. Requires a rebuild after install
# (expo run:android) — the native module doesn't load on a JS-only Metro reload.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
