{
  "name": "clickretina",
  "version": "0.0.0",
  "private": true,
  "description": "ClickRetina monorepo (backend + mobile + shared contract)",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:contract": "pnpm --filter @clickretina/contract build",
    "dev:api": "pnpm --filter @clickretina/api dev",
    "dev:worker": "pnpm --filter @clickretina/api worker",
    "build:api": "pnpm --filter @clickretina/api build",
    "start:api": "pnpm --filter @clickretina/api start",
    "start:worker": "pnpm --filter @clickretina/api start:worker",
    "dev:mobile": "pnpm --filter @clickretina/mobile start",
    "android:mobile": "pnpm --filter @clickretina/mobile android",
    "ios:mobile": "pnpm --filter @clickretina/mobile ios"
  },
  "dependencies": {
    "expo": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0"
  }
}
