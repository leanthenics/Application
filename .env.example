# --- API ---
PORT=54321
MAX_BODY_SIZE=10mb

# --- Redis / BullMQ ---
# Local: redis://127.0.0.1:6379
# Upstash (cloud, TLS): rediss://default:<password>@<host>.upstash.io:6379
#   (use the "ioredis" connection string from the Upstash console; ioredis auto-enables TLS for rediss://)
REDIS_URL=redis://127.0.0.1:6379
JOB_TTL_SECONDS=600

# --- Amazon affiliate ---
AMAZON_TLD=in
AMAZON_AFFILIATE_TAG=

# --- Gemini (models 1 & 3) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=30000

# --- Replicate (model 2: image edit) ---
REPLICATE_API_TOKEN=
# Which image-edit model family to use. Switching providers is a pure env swap
# (no code change) — set REPLICATE_PROVIDER + the matching REPLICATE_MODEL:
#   qwen     -> REPLICATE_MODEL=<qwen image 2.0 model id/version>
#   kontext  -> REPLICATE_MODEL=black-forest-labs/flux-kontext-pro
REPLICATE_PROVIDER=qwen
REPLICATE_MODEL=
REPLICATE_TIMEOUT_MS=120000

# --- AI retry (transient 429/503) ---
AI_MAX_RETRIES=3
AI_RETRY_BASE_MS=500
